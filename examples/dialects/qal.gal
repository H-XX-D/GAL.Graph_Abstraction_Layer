@gal netlist.v0
@dialect qal.v0

slo_api_latency "API latency SLO" target(0.95) actual(0.92) [kind: slo]
measurement_p95 "API p95 latency measurement" score(0.92) [kind: measurement]
measures> slo_api_latency(1.0)
violates> criterion_latency(0.7)
net quality_ok and2 passing measured
addf detect_regression0 quality [target: slo_api_latency] [window: 7d]
